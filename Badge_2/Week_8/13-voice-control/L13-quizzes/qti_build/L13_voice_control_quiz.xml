<?xml version="1.0" encoding="UTF-8"?>
<questestinterop xmlns="http://www.imsglobal.org/xsd/ims_qtiasiv1p2" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.imsglobal.org/xsd/ims_qtiasiv1p2 http://www.imsglobal.org/xsd/ims_qtiasiv1p2p1.xsd">
  <assessment ident="L13_voice_control_quiz" title="L13: Voice Control Quiz">
    <qtimetadata>
      <qtimetadatafield>
        <fieldlabel>cc_maxattempts</fieldlabel>
        <fieldentry>unlimited</fieldentry>
      </qtimetadatafield>
      <qtimetadatafield>
        <fieldlabel>qmd_timelimit</fieldlabel>
        <fieldentry/>
      </qtimetadatafield>
      <qtimetadatafield>
        <fieldlabel>cc_profile</fieldlabel>
        <fieldentry>cc.exam.v0p1</fieldentry>
      </qtimetadatafield>
    </qtimetadata>
    <section ident="root_section">
      
      <!-- Question 1: Duplicate Accessible Names (2D.02) -->
      <item ident="q1_duplicate_names" title="Q1: Duplicate Accessible Names">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>question_type</fieldlabel>
              <fieldentry>multiple_choice_question</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>points_possible</fieldlabel>
              <fieldentry>1</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>original_answer_ids</fieldlabel>
              <fieldentry>q1_a,q1_b,q1_c,q1_d</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material>
            <mattext texttype="text/html"><![CDATA[<p>If a voice control user says "click Download" on a page with three identical "Download" buttons, what will the system likely do?</p>]]></mattext>
          </material>
          <response_lid ident="response1" rcardinality="Single">
            <render_choice shuffle="true">
              <response_label ident="q1_a">
                <material>
                  <mattext texttype="text/plain">Display a disambiguation prompt with numbers</mattext>
                </material>
              </response_label>
              <response_label ident="q1_b">
                <material>
                  <mattext texttype="text/plain">Refresh the page to clear the conflict</mattext>
                </material>
              </response_label>
              <response_label ident="q1_c">
                <material>
                  <mattext texttype="text/plain">Ignore the command and play an error sound</mattext>
                </material>
              </response_label>
              <response_label ident="q1_d">
                <material>
                  <mattext texttype="text/plain">Download the first file automatically</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q1_a</varequal>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="q1_a_fb"/>
          </respcondition>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q1_b</varequal>
            </conditionvar>
            <displayfeedback feedbacktype="Response" linkrefid="q1_b_fb"/>
          </respcondition>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q1_c</varequal>
            </conditionvar>
            <displayfeedback feedbacktype="Response" linkrefid="q1_c_fb"/>
          </respcondition>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q1_d</varequal>
            </conditionvar>
            <displayfeedback feedbacktype="Response" linkrefid="q1_d_fb"/>
          </respcondition>
        </resprocessing>
        <itemfeedback ident="q1_a_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Correct.</strong> When names are duplicated, the system asks the user to clarify which specific element they intended to activate.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
        <itemfeedback ident="q1_b_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Incorrect.</strong> Voice control tools do not refresh the page. They resolve ambiguity through disambiguation prompts, not by clearing the DOM.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
        <itemfeedback ident="q1_c_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Incorrect.</strong> Voice control tools do not ignore valid commands. The command is valid because matching elements exist; the issue is that multiple elements match, so the system prompts for clarification.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
        <itemfeedback ident="q1_d_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Incorrect.</strong> Most voice control tools do not silently pick the first match when duplicates exist. Doing so would give users no control over which element is activated.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
      </item>

      <!-- Question 2: Keyboard Accessibility Prerequisite (2D.01) -->
      <item ident="q2_keyboard_prerequisite" title="Q2: Keyboard Accessibility Prerequisite">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>question_type</fieldlabel>
              <fieldentry>multiple_choice_question</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>points_possible</fieldlabel>
              <fieldentry>1</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>original_answer_ids</fieldlabel>
              <fieldentry>q2_a,q2_b,q2_c,q2_d</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material>
            <mattext texttype="text/html"><![CDATA[<p>Why is ensuring keyboard accessibility (WCAG 2.1.1) considered a prerequisite for voice control accessibility?</p>]]></mattext>
          </material>
          <response_lid ident="response1" rcardinality="Single">
            <render_choice shuffle="true">
              <response_label ident="q2_a">
                <material>
                  <mattext texttype="text/plain">Voice control tools often send keyboard events to the browser to trigger actions</mattext>
                </material>
              </response_label>
              <response_label ident="q2_b">
                <material>
                  <mattext texttype="text/plain">It is a legal requirement but has no technical impact on voice tools</mattext>
                </material>
              </response_label>
              <response_label ident="q2_c">
                <material>
                  <mattext texttype="text/plain">Voice users are required to have a physical keyboard plugged in</mattext>
                </material>
              </response_label>
              <response_label ident="q2_d">
                <material>
                  <mattext texttype="text/plain">Keyboard events are faster for the CPU to process than voice data</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q2_a</varequal>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="q2_a_fb"/>
          </respcondition>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q2_b</varequal>
            </conditionvar>
            <displayfeedback feedbacktype="Response" linkrefid="q2_b_fb"/>
          </respcondition>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q2_c</varequal>
            </conditionvar>
            <displayfeedback feedbacktype="Response" linkrefid="q2_c_fb"/>
          </respcondition>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q2_d</varequal>
            </conditionvar>
            <displayfeedback feedbacktype="Response" linkrefid="q2_d_fb"/>
          </respcondition>
        </resprocessing>
        <itemfeedback ident="q2_a_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Correct.</strong> Many voice commands, like "press enter" or "tab," rely on the underlying keyboard infrastructure of the application.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
        <itemfeedback ident="q2_b_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Incorrect.</strong> Keyboard accessibility has a direct technical impact. Voice control tools simulate keyboard events, so if an element is not keyboard operable, voice commands that rely on keyboard events will fail.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
        <itemfeedback ident="q2_c_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Incorrect.</strong> Voice control users do not need a physical keyboard. The entire point of voice control is to replace keyboard and mouse input with spoken commands.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
        <itemfeedback ident="q2_d_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Incorrect.</strong> CPU processing speed of keyboard events versus voice data is not relevant. The relationship is about voice control tools translating spoken commands into keyboard events that the application must be able to handle.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
      </item>

      <!-- Question 3: Hover-Triggered Menu Barrier (2D.02) -->
      <item ident="q3_hover_barrier" title="Q3: Hover-Triggered Menu Barrier">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>question_type</fieldlabel>
              <fieldentry>multiple_choice_question</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>points_possible</fieldlabel>
              <fieldentry>1</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>original_answer_ids</fieldlabel>
              <fieldentry>q3_a,q3_b,q3_c,q3_d</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material>
            <mattext texttype="text/html"><![CDATA[<p>How do hover-triggered menus create a barrier for voice control users?</p>]]></mattext>
          </material>
          <response_lid ident="response1" rcardinality="Single">
            <render_choice shuffle="true">
              <response_label ident="q3_a">
                <material>
                  <mattext texttype="text/plain">The menu may disappear as soon as the user attempts to speak a command</mattext>
                </material>
              </response_label>
              <response_label ident="q3_b">
                <material>
                  <mattext texttype="text/plain">Hover menus are always automatically keyboard accessible</mattext>
                </material>
              </response_label>
              <response_label ident="q3_c">
                <material>
                  <mattext texttype="text/plain">Voice control only works with static text and not interactive links</mattext>
                </material>
              </response_label>
              <response_label ident="q3_d">
                <material>
                  <mattext texttype="text/plain">Voice control cannot detect color changes on hover</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q3_a</varequal>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="q3_a_fb"/>
          </respcondition>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q3_b</varequal>
            </conditionvar>
            <displayfeedback feedbacktype="Response" linkrefid="q3_b_fb"/>
          </respcondition>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q3_c</varequal>
            </conditionvar>
            <displayfeedback feedbacktype="Response" linkrefid="q3_c_fb"/>
          </respcondition>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q3_d</varequal>
            </conditionvar>
            <displayfeedback feedbacktype="Response" linkrefid="q3_d_fb"/>
          </respcondition>
        </resprocessing>
        <itemfeedback ident="q3_a_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Correct.</strong> Voice processing takes a moment, and if the interface requires a constant hover state, the target might be lost before the command executes.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
        <itemfeedback ident="q3_b_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Incorrect.</strong> Hover menus are not always keyboard accessible. This is a separate issue, but stating they are "always" accessible is factually incorrect. The barrier for voice control users is the timing and persistence problem: the menu disappears before the voice command can execute.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
        <itemfeedback ident="q3_c_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Incorrect.</strong> Voice control works with all interactive elements, not just static text. It can activate links, buttons, form fields, and other controls as long as they have accessible names.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
        <itemfeedback ident="q3_d_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Incorrect.</strong> Voice control does not need to detect color changes. It targets elements by their accessible names in the accessibility tree, not by visual styling. The barrier is about the menu disappearing, not about color.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
      </item>

      <!-- Question 4: Label in Name Failure for Form Fields (2D.03) -->
      <item ident="q4_label_in_name" title="Q4: Label in Name Failure for Form Fields">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>question_type</fieldlabel>
              <fieldentry>multiple_choice_question</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>points_possible</fieldlabel>
              <fieldentry>1</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>original_answer_ids</fieldlabel>
              <fieldentry>q4_a,q4_b,q4_c,q4_d</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material>
            <mattext texttype="text/html"><![CDATA[<p>Which of the following describes a "Label in Name" failure related to form fields?</p>]]></mattext>
          </material>
          <response_lid ident="response1" rcardinality="Single">
            <render_choice shuffle="true">
              <response_label ident="q4_a">
                <material>
                  <mattext texttype="text/plain">An input field has a visible label "Email" but the aria-label is "Enter your contact address"</mattext>
                </material>
              </response_label>
              <response_label ident="q4_b">
                <material>
                  <mattext texttype="text/plain">The form uses a label element that is correctly linked using "for" and "id" attributes</mattext>
                </material>
              </response_label>
              <response_label ident="q4_c">
                <material>
                  <mattext texttype="text/plain">An input field has a placeholder but no visible label</mattext>
                </material>
              </response_label>
              <response_label ident="q4_d">
                <material>
                  <mattext texttype="text/plain">The submit button for a form is placed at the top of the page</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q4_a</varequal>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="q4_a_fb"/>
          </respcondition>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q4_b</varequal>
            </conditionvar>
            <displayfeedback feedbacktype="Response" linkrefid="q4_b_fb"/>
          </respcondition>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q4_c</varequal>
            </conditionvar>
            <displayfeedback feedbacktype="Response" linkrefid="q4_c_fb"/>
          </respcondition>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q4_d</varequal>
            </conditionvar>
            <displayfeedback feedbacktype="Response" linkrefid="q4_d_fb"/>
          </respcondition>
        </resprocessing>
        <itemfeedback ident="q4_a_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Correct.</strong> Since the aria-label does not include the visible text "Email," a user saying "click Email" will fail to focus the field.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
        <itemfeedback ident="q4_b_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Incorrect.</strong> A correctly linked label element is proper implementation, not a failure. When the label is programmatically associated and the accessible name matches the visible text, Label in Name is satisfied.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
        <itemfeedback ident="q4_c_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Incorrect.</strong> A placeholder without a visible label is a different accessibility issue (related to WCAG 1.3.1 and 3.3.2), not a Label in Name failure. Label in Name (2.5.3) specifically requires the accessible name to contain the visible text when visible text exists.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
        <itemfeedback ident="q4_d_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Incorrect.</strong> Button placement is a usability and layout concern, not a Label in Name issue. WCAG 2.5.3 is about matching accessible names to visible text, not about element positioning.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
      </item>

      <!-- Question 5: Auditing with Developer Tools (2D.02) -->
      <item ident="q5_devtools_audit" title="Q5: Auditing with Developer Tools">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>question_type</fieldlabel>
              <fieldentry>multiple_choice_question</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>points_possible</fieldlabel>
              <fieldentry>1</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>original_answer_ids</fieldlabel>
              <fieldentry>q5_a,q5_b,q5_c,q5_d</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material>
            <mattext texttype="text/html"><![CDATA[<p>When using browser developer tools to audit for voice control, what should you compare against the visible text on the screen?</p>]]></mattext>
          </material>
          <response_lid ident="response1" rcardinality="Single">
            <render_choice shuffle="true">
              <response_label ident="q5_a">
                <material>
                  <mattext texttype="text/plain">The computed accessible name in the Accessibility panel</mattext>
                </material>
              </response_label>
              <response_label ident="q5_b">
                <material>
                  <mattext texttype="text/plain">The file size of the page's images</mattext>
                </material>
              </response_label>
              <response_label ident="q5_c">
                <material>
                  <mattext texttype="text/plain">The DOM element's class name</mattext>
                </material>
              </response_label>
              <response_label ident="q5_d">
                <material>
                  <mattext texttype="text/plain">The z-index value of the element</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q5_a</varequal>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="q5_a_fb"/>
          </respcondition>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q5_b</varequal>
            </conditionvar>
            <displayfeedback feedbacktype="Response" linkrefid="q5_b_fb"/>
          </respcondition>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q5_c</varequal>
            </conditionvar>
            <displayfeedback feedbacktype="Response" linkrefid="q5_c_fb"/>
          </respcondition>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q5_d</varequal>
            </conditionvar>
            <displayfeedback feedbacktype="Response" linkrefid="q5_d_fb"/>
          </respcondition>
        </resprocessing>
        <itemfeedback ident="q5_a_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Correct.</strong> The computed name is what the browser actually sends to the accessibility tree and what the voice tool will try to match.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
        <itemfeedback ident="q5_b_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Incorrect.</strong> Image file size has no relationship to voice control accessibility. It affects performance but does not influence how voice control tools identify or target elements.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
        <itemfeedback ident="q5_c_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Incorrect.</strong> CSS class names are developer conventions for styling and scripting. They are not exposed to the accessibility tree and have no bearing on what voice control tools use to match spoken commands to elements.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
        <itemfeedback ident="q5_d_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Incorrect.</strong> The z-index property controls visual stacking order of elements. It does not affect accessible names or how voice control tools identify interactive targets.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
      </item>

    </section>
  </assessment>
</questestinterop>
