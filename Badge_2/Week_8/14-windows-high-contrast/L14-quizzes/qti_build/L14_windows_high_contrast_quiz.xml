    <section ident="root_section">

      <!-- Question 1: WHCM vs Dark Mode (2E.01) -->
      <item ident="q1_whcm_vs_dark" title="Q1: WHCM vs Dark Mode">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>question_type</fieldlabel>
              <fieldentry>multiple_choice_question</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>points_possible</fieldlabel>
              <fieldentry>1</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>original_answer_ids</fieldlabel>
              <fieldentry>q1_a,q1_b,q1_c,q1_d</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material>
            <mattext texttype="text/html"><![CDATA[<p>In what primary way does Windows High Contrast Mode (Forced Colors) differ from a standard "Dark Mode" implementation?</p>]]></mattext>
          </material>
          <response_lid ident="response1" rcardinality="Single">
            <render_choice shuffle="true">
              <response_label ident="q1_a">
                <material>
                  <mattext texttype="text/plain">Forced colors give the user full control over the specific palette, whereas Dark Mode provides author-defined color schemes.</mattext>
                </material>
              </response_label>
              <response_label ident="q1_b">
                <material>
                  <mattext texttype="text/plain">Dark Mode is a system-level override, while forced colors are controlled by the website author.</mattext>
                </material>
              </response_label>
              <response_label ident="q1_c">
                <material>
                  <mattext texttype="text/plain">Dark Mode is required by WCAG 2.1, while High Contrast Mode is considered an optional enhancement.</mattext>
                </material>
              </response_label>
              <response_label ident="q1_d">
                <material>
                  <mattext texttype="text/plain">Forced colors only affect text elements, whereas Dark Mode affects the entire UI including images.</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q1_a</varequal>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="q1_a_fb"/>
          </respcondition>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q1_b</varequal>
            </conditionvar>
            <displayfeedback feedbacktype="Response" linkrefid="q1_b_fb"/>
          </respcondition>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q1_c</varequal>
            </conditionvar>
            <displayfeedback feedbacktype="Response" linkrefid="q1_c_fb"/>
          </respcondition>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q1_d</varequal>
            </conditionvar>
            <displayfeedback feedbacktype="Response" linkrefid="q1_d_fb"/>
          </respcondition>
        </resprocessing>
        <itemfeedback ident="q1_a_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Correct.</strong> High Contrast Mode allows users to define or choose their own system keywords, whereas Dark Mode usually relies on a prefers-color-scheme query where the designer still chooses the hex values.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
        <itemfeedback ident="q1_b_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Incorrect.</strong> The roles are reversed: forced colors are the system-level override applied by the user's OS/browser, while Dark Mode implementations are typically author-defined (or author-chosen in response to a media query).</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
        <itemfeedback ident="q1_c_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Incorrect.</strong> Neither Dark Mode nor High Contrast Mode is required by WCAG 2.1. Both are user-preference features. WCAG does not mandate one over the other as optional.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
        <itemfeedback ident="q1_d_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Incorrect.</strong> Forced colors affect the entire UI (backgrounds, borders, text, and often SVG fill/stroke), not just text. Dark Mode also typically affects the full UI, including images when authors choose to adapt them.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
      </item>

      <!-- Question 2: GrayText (2E.02) -->
      <item ident="q2_graytext" title="Q2: System Color for Disabled Text">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>question_type</fieldlabel>
              <fieldentry>multiple_choice_question</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>points_possible</fieldlabel>
              <fieldentry>1</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>original_answer_ids</fieldlabel>
              <fieldentry>q2_a,q2_b,q2_c,q2_d</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material>
            <mattext texttype="text/html"><![CDATA[<p>Which system color keyword is used to represent disabled text in High Contrast Mode?</p>]]></mattext>
          </material>
          <response_lid ident="response1" rcardinality="Single">
            <render_choice shuffle="true">
              <response_label ident="q2_a">
                <material>
                  <mattext texttype="text/plain">GrayText</mattext>
                </material>
              </response_label>
              <response_label ident="q2_b">
                <material>
                  <mattext texttype="text/plain">CanvasText</mattext>
                </material>
              </response_label>
              <response_label ident="q2_c">
                <material>
                  <mattext texttype="text/plain">ButtonText</mattext>
                </material>
              </response_label>
              <response_label ident="q2_d">
                <material>
                  <mattext texttype="text/plain">HighlightText</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q2_a</varequal>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="q2_a_fb"/>
          </respcondition>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q2_b</varequal>
            </conditionvar>
            <displayfeedback feedbacktype="Response" linkrefid="q2_b_fb"/>
          </respcondition>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q2_c</varequal>
            </conditionvar>
            <displayfeedback feedbacktype="Response" linkrefid="q2_c_fb"/>
          </respcondition>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q2_d</varequal>
            </conditionvar>
            <displayfeedback feedbacktype="Response" linkrefid="q2_d_fb"/>
          </respcondition>
        </resprocessing>
        <itemfeedback ident="q2_a_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Correct.</strong> GrayText is the specific system keyword mapped to disabled or inactive text elements.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
        <itemfeedback ident="q2_b_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Incorrect.</strong> CanvasText is the system keyword for normal text on the Canvas (page) background, not for disabled text.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
        <itemfeedback ident="q2_c_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Incorrect.</strong> ButtonText is used for the text on button faces, not for disabled or inactive content.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
        <itemfeedback ident="q2_d_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Incorrect.</strong> HighlightText is used for text within a selection highlight, not for disabled text.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
      </item>

      <!-- Question 3: currentColor and SVG (2E.02) -->
      <item ident="q3_currentcolor_svg" title="Q3: currentColor and SVG in WHCM">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>question_type</fieldlabel>
              <fieldentry>multiple_choice_question</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>points_possible</fieldlabel>
              <fieldentry>1</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>original_answer_ids</fieldlabel>
              <fieldentry>q3_a,q3_b,q3_c,q3_d</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material>
            <mattext texttype="text/html"><![CDATA[<p>In a complex SVG icon, setting the "fill" attribute to "currentColor" ensures visibility in High Contrast Mode because:</p>]]></mattext>
          </material>
          <response_lid ident="response1" rcardinality="Single">
            <render_choice shuffle="true">
              <response_label ident="q3_a">
                <material>
                  <mattext texttype="text/plain">It causes the icon to inherit the forced text color (CanvasText), ensuring it contrasts with the background.</mattext>
                </material>
              </response_label>
              <response_label ident="q3_b">
                <material>
                  <mattext texttype="text/plain">It allows the icon to inherit the value of the "Canvas" keyword.</mattext>
                </material>
              </response_label>
              <response_label ident="q3_c">
                <material>
                  <mattext texttype="text/plain">It prevents the system from overriding the SVG's internal CSS styles.</mattext>
                </material>
              </response_label>
              <response_label ident="q3_d">
                <material>
                  <mattext texttype="text/plain">It forces the system to ignore the SVG entirely and use a text fallback.</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q3_a</varequal>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="q3_a_fb"/>
          </respcondition>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q3_b</varequal>
            </conditionvar>
            <displayfeedback feedbacktype="Response" linkrefid="q3_b_fb"/>
          </respcondition>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q3_c</varequal>
            </conditionvar>
            <displayfeedback feedbacktype="Response" linkrefid="q3_c_fb"/>
          </respcondition>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q3_d</varequal>
            </conditionvar>
            <displayfeedback feedbacktype="Response" linkrefid="q3_d_fb"/>
          </respcondition>
        </resprocessing>
        <itemfeedback ident="q3_a_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Correct.</strong> Since the text color is guaranteed to contrast with the background in WHCM, inheriting that color ensures the icon remains visible.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
        <itemfeedback ident="q3_b_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Incorrect.</strong> Canvas is the background keyword, not the text color. Inheriting Canvas would make the icon the same color as the background and invisible.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
        <itemfeedback ident="q3_c_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Incorrect.</strong> The system does override colors in forced colors mode; currentColor works because it inherits the (overridden) text color, not because it blocks overrides.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
        <itemfeedback ident="q3_d_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Incorrect.</strong> currentColor does not cause the system to ignore the SVG or replace it with text. The SVG is still rendered; its fill is replaced by the inherited text color.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
      </item>

      <!-- Question 4: Transparent border (2E.03) -->
      <item ident="q4_transparent_border" title="Q4: Transparent Border for Button">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>question_type</fieldlabel>
              <fieldentry>multiple_choice_question</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>points_possible</fieldlabel>
              <fieldentry>1</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>original_answer_ids</fieldlabel>
              <fieldentry>q4_a,q4_b,q4_c,q4_d</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material>
            <mattext texttype="text/html"><![CDATA[<p>A developer wants to ensure that a "Submit" button has a visible border in High Contrast Mode but remains borderless in the standard view. Which CSS should be applied to the button's default state?</p>]]></mattext>
          </material>
          <response_lid ident="response1" rcardinality="Single">
            <render_choice shuffle="true">
              <response_label ident="q4_a">
                <material>
                  <mattext texttype="text/plain">border: 2px solid transparent;</mattext>
                </material>
              </response_label>
              <response_label ident="q4_b">
                <material>
                  <mattext texttype="text/plain">outline: 2px solid ButtonText;</mattext>
                </material>
              </response_label>
              <response_label ident="q4_c">
                <material>
                  <mattext texttype="text/plain">box-shadow: 0 0 0 2px black;</mattext>
                </material>
              </response_label>
              <response_label ident="q4_d">
                <material>
                  <mattext texttype="text/plain">border: none;</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q4_a</varequal>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="q4_a_fb"/>
          </respcondition>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q4_b</varequal>
            </conditionvar>
            <displayfeedback feedbacktype="Response" linkrefid="q4_b_fb"/>
          </respcondition>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q4_c</varequal>
            </conditionvar>
            <displayfeedback feedbacktype="Response" linkrefid="q4_c_fb"/>
          </respcondition>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q4_d</varequal>
            </conditionvar>
            <displayfeedback feedbacktype="Response" linkrefid="q4_d_fb"/>
          </respcondition>
        </resprocessing>
        <itemfeedback ident="q4_a_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Correct.</strong> A transparent border is invisible in normal mode but its color will be overridden by the system in High Contrast Mode, making it visible.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
        <itemfeedback ident="q4_b_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Incorrect.</strong> Outline would be visible in normal mode (unless the color were transparent), and outline is conventionally reserved for focus indicators rather than persistent button boundaries.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
        <itemfeedback ident="q4_c_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Incorrect.</strong> box-shadow is removed entirely in forced colors mode, so it would not provide a visible boundary in High Contrast Mode.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
        <itemfeedback ident="q4_d_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Incorrect.</strong> border: none leaves no border for the system to recolor; the boundary stays invisible in High Contrast Mode.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
      </item>

      <!-- Question 5: Prioritizing failures (2E.02) -->
      <item ident="q5_prioritize_failures" title="Q5: Prioritizing WHCM Failures">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>question_type</fieldlabel>
              <fieldentry>multiple_choice_question</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>points_possible</fieldlabel>
              <fieldentry>1</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>original_answer_ids</fieldlabel>
              <fieldentry>q5_a,q5_b,q5_c,q5_d</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material>
            <mattext texttype="text/html"><![CDATA[<p>Which of the following failures should be addressed first?</p>]]></mattext>
          </material>
          <response_lid ident="response1" rcardinality="Single">
            <render_choice shuffle="true">
              <response_label ident="q5_a">
                <material>
                  <mattext texttype="text/plain">The keyboard focus indicator becoming completely invisible on interactive links.</mattext>
                </material>
              </response_label>
              <response_label ident="q5_b">
                <material>
                  <mattext texttype="text/plain">Card components losing their subtle dropshadow boundaries.</mattext>
                </material>
              </response_label>
              <response_label ident="q5_c">
                <material>
                  <mattext texttype="text/plain">Brand logos losing their specific corporate hex colors.</mattext>
                </material>
              </response_label>
              <response_label ident="q5_d">
                <material>
                  <mattext texttype="text/plain">Success and Error messages losing their green and red background colors.</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q5_a</varequal>
            </conditionvar>
            <setvar action="Set" varname="SCORE">100</setvar>
            <displayfeedback feedbacktype="Response" linkrefid="q5_a_fb"/>
          </respcondition>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q5_b</varequal>
            </conditionvar>
            <displayfeedback feedbacktype="Response" linkrefid="q5_b_fb"/>
          </respcondition>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q5_c</varequal>
            </conditionvar>
            <displayfeedback feedbacktype="Response" linkrefid="q5_c_fb"/>
          </respcondition>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">q5_d</varequal>
            </conditionvar>
            <displayfeedback feedbacktype="Response" linkrefid="q5_d_fb"/>
          </respcondition>
        </resprocessing>
        <itemfeedback ident="q5_a_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Correct.</strong> Focus indicator loss is a Tier 1 (Critical) failure because it prevents keyboard users from navigating the interface.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
        <itemfeedback ident="q5_b_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Incorrect.</strong> Losing dropshadow boundaries on cards is a lower-priority failure; content and structure remain perceivable. It should be fixed but after critical issues like focus visibility.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
        <itemfeedback ident="q5_c_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Incorrect.</strong> Brand color loss in logos is a visual/brand concern in forced colors. It does not block access to content or operation and is lower priority than focus visibility.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
        <itemfeedback ident="q5_d_fb">
          <flow_mat>
            <material>
              <mattext texttype="text/html"><![CDATA[<p><strong>Incorrect.</strong> Losing semantic color (green/red) on messages is important for clarity but can be mitigated with icons or text. Invisible focus is a direct barrier to keyboard navigation and should be fixed first.</p>]]></mattext>
            </material>
          </flow_mat>
        </itemfeedback>
      </item>

    </section>
  </assessment>
</questestinterop>
