# Database (Postgres URL from Vercel Marketplace / Neon or local)
DATABASE_URL=

# Teacher portal: long random string; set the same value in Vercel production env.
# Never commit .env.local or paste the live /teacher?token=... URL into git.
ADMIN_SECRET=

# Upstash Redis (optional - quizzes work without it, scores just won't be saved)
# Get these from: https://console.upstash.com/ or `vercel integration add upstash`
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
